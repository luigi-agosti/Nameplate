MAC_RELEASE_APP_NAME=Nameplate
MAC_RELEASE_REPO=steipete/Nameplate
MAC_RELEASE_BUNDLE_ID=com.steipete.nameplate
MAC_RELEASE_VERSION_FILE=version.env
MAC_RELEASE_APPCAST=appcast.xml
MAC_RELEASE_SUPUBLIC_ED_KEY=PuuzNa/yoisEbFEZOkuwW1Su3Y/RD3Rph8cAk8+VZ4Y=
# Explicit Keychain account (Sparkle default); also keeps account_args
# non-empty for stock bash 3.2's set -u empty-array behavior.
MAC_RELEASE_SPARKLE_ACCOUNT=ed25519

MAC_RELEASE_APP_ZIP='Nameplate-${MARKETING_VERSION}.zip'
MAC_RELEASE_REQUIRE_DSYM=0
MAC_RELEASE_ARTIFACT_PREFIX='Nameplate-'
MAC_RELEASE_FEED_URL='https://raw.githubusercontent.com/steipete/Nameplate/main/appcast.xml'
MAC_RELEASE_DOWNLOAD_URL_PREFIX='https://github.com/steipete/Nameplate/releases/download/v${MARKETING_VERSION}/'

MAC_RELEASE_PRECHECK='DEVELOPER_DIR=/Applications/Xcode.app swift test'
MAC_RELEASE_PACKAGE_CMD='Scripts/sign-and-notarize.sh'
MAC_RELEASE_OP_ITEM='API Key - App Store Connect - Personal - Release'
MAC_RELEASE_OP_FIELDS='private_key_p8 key_id issuer_id'
MAC_RELEASE_OP_VAULT=Molty
MAC_RELEASE_TAG_SIGNED=0
MAC_RELEASE_TAG_FORCE=0
MAC_RELEASE_TAG_ANNOTATED=0
MAC_RELEASE_GENERATE_APPCAST_ARGS='--maximum-deltas 0'
MAC_RELEASE_EXTRA_ASSET_PATTERNS='Nameplate.zip'
